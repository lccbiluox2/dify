# Dify 内网断网部署环境变量补丁
# Docker Compose 用法：将以下内容合并到 docker/.env，然后 docker compose up -d
# K8s 用户请使用同目录 dify-offline-hardening.sh

# ----- P0：插件 PyPI 镜像（必配，按实际内网地址修改）-----
PIP_MIRROR_URL=http://pypiserver:8080/simple/
# Plugin Daemon 额外变量（docker-compose 需在 plugin_daemon 段手动添加，见下方说明）
# PLUGIN_IGNORE_UV_LOCK=true

# ----- P1：关闭 Dify 官方外网服务 -----
MARKETPLACE_ENABLED=false
MARKETPLACE_API_URL=
MARKETPLACE_URL=
CHECK_UPDATE_URL=
CREATORS_PLATFORM_FEATURES_ENABLED=false
CREATORS_PLATFORM_API_URL=
ENABLE_CHECK_UPGRADABLE_PLUGIN_TASK=false
HOSTED_FETCH_APP_TEMPLATES_MODE=builtin
HOSTED_FETCH_PIPELINE_TEMPLATES_MODE=builtin

# ----- P2：关闭可选出站功能 -----
ENABLE_WEBSITE_JINAREADER=false
ENABLE_WEBSITE_FIRECRAWL=false
ENABLE_WEBSITE_WATERCRAWL=false
SANDBOX_ENABLE_NETWORK=false

# ----- 遥测 -----
NEXT_TELEMETRY_DISABLED=1
WEAVIATE_DISABLE_TELEMETRY=true
SCARF_NO_ANALYTICS=true
API_SENTRY_DSN=
WEB_SENTRY_DSN=
PLUGIN_SENTRY_ENABLED=false
AMPLITUDE_API_KEY=

# ----- 版本标识 -----
EDITION=SELF_HOSTED

# Docker Compose 注意：
# PLUGIN_IGNORE_UV_LOCK 不在主仓库 docker-compose 模板中，
# 需在 docker-compose.yaml 的 plugin_daemon 服务 environment 下手动添加：
#   PLUGIN_IGNORE_UV_LOCK: ${PLUGIN_IGNORE_UV_LOCK:-true}
# 并在本文件增加：PLUGIN_IGNORE_UV_LOCK=true
